{
  "name": "even-agent-home",
  "version": "1.0.8",
  "description": "Agent Home backend — HTTP bridge server that exposes multi-provider AI agents (Claude, Codex, OpenCode, Hermes, Antigravity, oh-my-pi) to the Agent Home glasses client.",
  "main": "src/index.js",
  "type": "module",
  "bin": {
    "even-agent-home": "bin/even-agent-home.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "even-agent-home": "node bin/even-agent-home.js",
    "test": "node ../scripts/test-openclaw-provider.mjs && node ../scripts/test-pi-session-cwd-reuse.mjs && node ../scripts/test-codex-app-server-port.mjs",
    "test:openclaw": "node ../scripts/test-openclaw-provider.mjs",
    "test:pi-cwd": "node ../scripts/test-pi-session-cwd-reuse.mjs",
    "test:port": "node ../scripts/test-codex-app-server-port.mjs"
  },
  "keywords": [
    "ai",
    "agents",
    "claude",
    "codex",
    "opencode",
    "bridge",
    "glasses",
    "agent-home",
    "even-realities"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jalatif/even-agent-home.git",
    "directory": "backend"
  },
  "bugs": {
    "url": "https://github.com/jalatif/even-agent-home/issues"
  },
  "homepage": "https://github.com/jalatif/even-agent-home#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@huggingface/transformers": "^3.8.1",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "fast-xml-parser": "^5.8.0",
    "node-fetch": "^3.3.2",
    "qrcode-terminal": "^0.12.0",
    "uuid": "^14.0.0",
    "ws": "^8.21.0",
    "yargs": "^18.0.0"
  }
}

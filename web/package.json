{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:unit": "node --experimental-strip-types --no-warnings --test test/**/*.test.ts",
    "test:simulator": "node ../scripts/fuzzy-test.mjs",
    "test:recorded": "node ~/.agents/skills/even-simulator-replay/scripts/run-fixture.mjs \"$(git rev-parse --show-toplevel)/scripts/simulator-recorded-sessions/tests/**/*.fixture.json\"",
    "test:stt": "node ../scripts/test-stt-contract.mjs",
    "test:resume": "node ../scripts/test-claude-resume.mjs",
    "test:deps": "node ../scripts/test-dependency-presence.mjs",
    "test:all": "npm run test:unit && npm run test:deps && npm run test:resume && npm run test:stt"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.10",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
